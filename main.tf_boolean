provider "aws" {
  region = "ap-south-1"
}

variable "instance_type" {
  default = "t3.small"
}

variable "is_public" {
	default = false
}

resource "aws_instance" "web" {
  ami           = "ami-0e38835daf6b8a2b9"
  instance_type = var.instance_type
  associate_public_ip_address = var.is_public

  tags = {
    Name = "web-server"
  }
}
